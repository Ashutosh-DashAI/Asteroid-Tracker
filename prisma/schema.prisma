// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Assuming PostgreSQL for robust containerized deployment
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  passwordHash     String            // Hashed passwords for security
  name             String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  // Relations
  watchedAsteroids WatchedAsteroid[]
  alerts           Alert[]
  chatMessages     ChatMessage[]
}

model WatchedAsteroid {
  id                  String   @id @default(uuid())
  userId              String
  neoReferenceId      String   // The ID provided by the NASA NeoWs API
  name                String
  customAlertDistance Float?   // Optional custom threshold for alerts
  riskScore           Float?   // Cached/Calculated risk score based on hazard, diameter, etc.
  createdAt           DateTime @default(now())

  // Relations
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, neoReferenceId]) // Prevents duplicate tracking of the same asteroid by the same user
}

model Alert {
  id               String   @id @default(uuid())
  userId           String
  neoReferenceId   String
  message          String   // e.g., "Asteroid 433 Eros is making a close approach!"
  isRead           Boolean  @default(false)
  approachDate     DateTime 
  createdAt        DateTime @default(now())

  // Relations
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Bonus: Real-time Chat Thread
model ChatMessage {
  id               String   @id @default(uuid())
  userId           String
  neoReferenceId   String   // Represents the specific asteroid thread
  message          String
  createdAt        DateTime @default(now())

  // Relations
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}