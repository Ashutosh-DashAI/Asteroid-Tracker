// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USER MODEL
// ============================================
model User {
  id               String           @id @default(uuid())
  name             String
  email            String           @unique
  passwordHash     String
  username         String?
  avatar           String?
  bio              String?
  role             UserRole         @default(USER)
  isVerified       Boolean          @default(false)
  isBanned         Boolean          @default(false)
  resetTokenHash   String?
  resetTokenExpire DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  refreshTokens    RefreshToken[]
  savedAsteroids   SavedAsteroid[]
  savedSearches    SavedSearch[]
  alertPreferences AlertPreference[]
  notifications    Notification[]

  @@index([email])
}

enum UserRole {
  USER
  ADMIN
}

// ============================================
// REFRESH TOKEN MODEL
// ============================================
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// NOTIFICATION MODEL (Asteroid-only)
// ============================================
model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   @default("ALERT") // ALERT, SYSTEM
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

// ============================================
// ASTEROID MODEL
// ============================================
model Asteroid {
  id                    String           @id @default(uuid())
  nasaId                String           @unique
  name                  String
  estimatedDiameterMin  Float            @default(0)
  estimatedDiameterMax  Float            @default(0)
  hazardous             Boolean          @default(false)
  absoluteMagnitude     Float
  orbitalClass          String?
  velocityKmPerSecond   Float?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  // Relations
  closeApproaches       CloseApproach[]
  savedAsteroids        SavedAsteroid[]

  @@index([nasaId])
  @@index([hazardous])
  @@index([createdAt])
}

// ============================================
// CLOSE APPROACH MODEL
// ============================================
model CloseApproach {
  id                  String   @id @default(uuid())
  asteroidId          String
  closeApproachDate   DateTime
  relativeVelocityKmS Float
  missDistanceKm      Float
  orbitingBody        String
  createdAt           DateTime @default(now())

  // Relations
  asteroid            Asteroid @relation(fields: [asteroidId], references: [id], onDelete: Cascade)

  @@index([asteroidId])
  @@index([closeApproachDate])
  @@unique([asteroidId, closeApproachDate])
}

// ============================================
// SAVED ASTEROID MODEL
// ============================================
model SavedAsteroid {
  id                   String   @id @default(uuid())
  userId               String
  asteroidId           String
  asteroidName         String
  hazardous            Boolean
  closeApproachDate    DateTime?
  missDistanceKm       Float?
  estimatedDiameterMin Float?
  estimatedDiameterMax Float?
  createdAt            DateTime @default(now())

  // Relations
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asteroid             Asteroid @relation(fields: [asteroidId], references: [id], onDelete: Cascade)

  @@unique([userId, asteroidId])
  @@index([userId])
  @@index([asteroidId])
}

// ============================================
// SAVED SEARCH MODEL
// ============================================
model SavedSearch {
  id           String   @id @default(uuid())
  userId       String
  name         String?
  startDate    DateTime
  endDate      DateTime
  hazardousOnly Boolean @default(false)
  minDiameter  Float?
  maxMissDistance Float?
  createdAt    DateTime @default(now())

  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// ALERT PREFERENCE MODEL
// ============================================
model AlertPreference {
  id              String   @id @default(uuid())
  userId          String   @unique
  hazardousOnly   Boolean  @default(true)
  minDiameter     Float?
  maxMissDistance Float?
  emailEnabled    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// ASTEROID CACHE MODEL
// ============================================
model AsteroidCache {
  id        String   @id @default(uuid())
  asteroidId String  @unique
  rawData   String   // Stores JSON stringified NASA response
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@index([asteroidId])
  @@index([expiresAt])
}

// ============================================
// API REQUEST LOG MODEL
// ============================================
model ApiRequestLog {
  id           String   @id @default(uuid())
  endpoint     String
  method       String
  statusCode   Int
  responseTime Int      // milliseconds
  userId       String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([endpoint])
  @@index([createdAt])
}