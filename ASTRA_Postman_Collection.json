{
  "info": {
    "_postman_id": "astra-asteroid-tracker",
    "name": "ASTRA - Asteroid Tracker API",
    "description": "Complete Postman collection for testing the ASTRA Full-Stack Asteroid Tracking Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"username\": \"johndoe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signup"]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('accessToken', data.data.tokens.accessToken);",
                  "  pm.environment.set('refreshToken', data.data.tokens.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          },
          "response": []
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "forgot-password"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Asteroids - Feed & Discovery",
      "item": [
        {
          "name": "Get Nearby Asteroids Feed",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/asteroids/feed?startDate=2026-04-01&endDate=2026-04-07",
              "host": ["{{baseUrl}}"],
              "path": ["api", "asteroids", "feed"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2026-04-01"
                },
                {
                  "key": "endDate",
                  "value": "2026-04-07"
                },
                {
                  "key": "hazardousOnly",
                  "value": "false",
                  "disabled": true
                },
                {
                  "key": "limit",
                  "value": "20",
                  "disabled": true
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Nearby Asteroids (Next 30 Days)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/asteroids/nearby?days=30",
              "host": ["{{baseUrl}}"],
              "path": ["api", "asteroids", "nearby"],
              "query": [
                {
                  "key": "days",
                  "value": "30"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Search Asteroids",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/asteroids/search?query=Apophis&hazardousOnly=false&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "asteroids", "search"],
              "query": [
                {
                  "key": "query",
                  "value": "Apophis"
                },
                {
                  "key": "hazardousOnly",
                  "value": "false"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Hazardous Asteroids Ranking",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/asteroids/hazardous/ranking?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "asteroids", "hazardous", "ranking"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Asteroids - Detailed Information",
      "item": [
        {
          "name": "Get Asteroid Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/asteroids/2099942",
              "host": ["{{baseUrl}}"],
              "path": ["api", "asteroids", "2099942"]
            }
          },
          "response": []
        },
        {
          "name": "Get Risk Analysis for Asteroid",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/asteroids/2099942/risk-analysis",
              "host": ["{{baseUrl}}"],
              "path": ["api", "asteroids", "2099942", "risk-analysis"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Asteroids - User Watchlist",
      "item": [
        {
          "name": "Add Asteroid to Watchlist",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"alertLevel\": \"HIGH\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/asteroids/{{asteroidId}}/watch",
              "host": ["{{baseUrl}}"],
              "path": ["api", "asteroids", "{{asteroidId}}", "watch"]
            }
          },
          "response": []
        },
        {
          "name": "Get User's Watched Asteroids",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/asteroids/watchlist",
              "host": ["{{baseUrl}}"],
              "path": ["api", "asteroids", "watchlist"]
            }
          },
          "response": []
        },
        {
          "name": "Remove Asteroid from Watchlist",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/asteroids/{{asteroidId}}/watch",
              "host": ["{{baseUrl}}"],
              "path": ["api", "asteroids", "{{asteroidId}}", "watch"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Alerts & Notifications",
      "item": [
        {
          "name": "Get User Alerts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/asteroids/alerts?includeRead=false",
              "host": ["{{baseUrl}}"],
              "path": ["api", "asteroids", "alerts"],
              "query": [
                {
                  "key": "includeRead",
                  "value": "false"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Mark Alert as Read",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/asteroids/alerts/{{alertId}}/read",
              "host": ["{{baseUrl}}"],
              "path": ["api", "asteroids", "alerts", "{{alertId}}", "read"]
            }
          },
          "response": []
        },
        {
          "name": "Create Manual Alert",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"alertType\": \"CLOSE_APPROACH\",\n  \"severity\": \"HIGH\",\n  \"message\": \"Asteroid 2099942 will have a close approach on 2026-04-10\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/asteroids/{{asteroidId}}/create-alert",
              "host": ["{{baseUrl}}"],
              "path": ["api", "asteroids", "{{asteroidId}}", "create-alert"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Server Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "asteroidId",
      "value": "3122519",
      "type": "string"
    },
    {
      "key": "alertId",
      "value": "",
      "type": "string"
    }
  ]
}
